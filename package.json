    "@tauri-apps/cli": "2.11.4",
    "@types/bun": "^1.2.21",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^1.8.8",
    "@cloudflare/workers-types": "^4.20250711.0",
    "drizzle-kit": "^0.31.8",
    "lefthook": "^2.1.9",
    "portless": "^0.15.1",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.9.2",
    "ultracite": "7.8.3",
    "uqr": "0.1.3",
    "vite": "^7.1.3",
    "wrangler": "^4.53.0"
  },
  "name": "quick-send",
  "scripts": {
    "dev": "bun run src/dev.ts",
    "dev:worker": "wrangler dev --port 8787",
    "dev:android": "adb reverse tcp:5173 tcp:5173 && tauri android dev --no-dev-server-wait --config '{\"build\":{\"beforeDevCommand\":null,\"devUrl\":\"http://127.0.0.1:5173\"}}'",
    "dev:mac": "tauri dev",
    "start": "vite --host 0.0.0.0",
    "start:app": "wrangler dev",
    "build": "bun run build:web && bun run typecheck",
    "build:web": "vite build",
    "typecheck": "tsc --noEmit",
    "check": "ultracite check",
    "check:fix": "ultracite fix",
    "prepare": "lefthook install",
    "test": "bun test",
    "tauri": "tauri",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply quick-send-v3 --local",
    "db:migrate": "wrangler d1 migrations apply quick-send-v3 --remote",
    "deploy": "bun run build:web && wrangler deploy"
  },
  "type": "module",
  "private": true
}
